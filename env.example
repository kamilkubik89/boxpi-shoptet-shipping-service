NODE_ENV=production
PORT=3000
APP_URL=https://your-addon.example.com
ALLOWED_ORIGINS=https://your-addon.example.com

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/boxpi_shoptet?schema=public
REDIS_URL=redis://redis:6379

SHOPTET_API_BASE_URL=https://api.myshoptet.com
SHOPTET_SCOPES=api-basic,api-orders,api-system,api-shipping-methods,api-webhooks
SHOPTET_INSTALL_TIMEOUT_MS=10000
SHOPTET_WEBHOOK_IP_ALLOWLIST=185.184.254.0/24

BOXPI_BASE_URL=https://test.api.boxpi.com/v2
BOXPI_API_KEY=replace-me
BOXPI_DEFAULT_CARRIER=PACKETA-POINT-SK
BOXPI_DEFAULT_COUNTRY=SK
BOXPI_DEFAULT_COD_CURRENCY=EUR

SHOPTET_ADDON_CODE=replace-me
SHOPTET_SHIPPING_METHOD_CODE=replace-me
SHOPTET_WIDGET_PUBLIC_URL=https://your-addon.example.com/public/boxpi-shipping.js
SHOPTET_WEBHOOK_URL=https://your-addon.example.com/api/webhooks/shoptet
SHOPTET_INSTALL_CALLBACK_URL=https://your-addon.example.com/api/install/shoptet
SHOPTET_SETTINGS_URL=https://your-addon.example.com/admin

DEFAULT_PICKUP_CARRIER=PACKETA-POINT-SK
PICKUP_POINTS_CACHE_TTL_SECONDS=900
SHIPPING_REQUEST_TTL_MINUTES=45
JOB_CONCURRENCY=5
HTTP_TIMEOUT_MS=15000
