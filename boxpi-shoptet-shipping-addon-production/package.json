{
  "name": "boxpi-shoptet-shipping-addon-production",
  "version": "1.0.0",
  "private": false,
  "description": "Production-oriented Shoptet shipping addon for Boxpi API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamilkubik89/boxpi-shoptet-shipping-addon"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "tsx src/modules/workers/worker.ts",
    "worker:prod": "node dist/modules/workers/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "axios": "^1.8.4",
    "bullmq": "^5.46.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.2.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.17",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
